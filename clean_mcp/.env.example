# Supported values: demo, sqlserver, mysql, postgresql, snowflake
DB_TYPE=demo
DB_HOST=demo-local
DB_DATABASE=qa_demo
DB_USERNAME=
DB_PASSWORD=
DB_TIMEOUT_SECONDS=30
DB_MAX_ROWS=500
DB_EXECUTION_MODE=read_write

# Optional named profiles for runtime switching. Keep real secrets in .env only.
# The agent lists profiles by name and cannot see credential values.
DB_ACTIVE_PROFILE=demo-local
DB_PROFILES_JSON={"demo-local":{"db_type":"demo","database":"qa_demo","execution_mode":"read_write"},"postgres-local":{"db_type":"postgresql","host":"localhost","database":"qa_demo","username":"qa_user","password":"change_me","execution_mode":"read_write","connection_options":{"port":5432}},"mysql-local":{"db_type":"mysql","host":"localhost","database":"qa_demo","username":"qa_user","password":"change_me","execution_mode":"read_write","connection_options":{"port":3306}},"snowflake-dev":{"db_type":"snowflake","host":"account_identifier","database":"QA_DEMO","username":"your_user","password":"change_me","execution_mode":"read_write","connection_options":{"warehouse":"COMPUTE_WH","schema":"PUBLIC","role":"ACCOUNTADMIN"}}}

# Demo connector (offline, no external database required):
# DB_TYPE=demo
# DB_HOST=demo-local
# DB_DATABASE=qa_demo

# SQL Server example:
# DB_TYPE=sqlserver
# DB_HOST=localhost
# DB_DATABASE=master
# DB_CONNECTION_OPTIONS={"driver":"ODBC Driver 18 for SQL Server","trusted_connection":true}

# MySQL example:
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_DATABASE=qa_demo
# DB_CONNECTION_OPTIONS={"port":3306}

# PostgreSQL example:
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_DATABASE=qa_demo
# DB_CONNECTION_OPTIONS={"port":5432}

# Snowflake example:
# DB_TYPE=snowflake
# DB_HOST=account_identifier
# DB_USERNAME=your_user
# DB_CONNECTION_OPTIONS={"warehouse":"COMPUTE_WH","schema":"PUBLIC","role":"ACCOUNTADMIN"}

LOG_LEVEL=INFO

# Optional smoke test connectivity check:
# DB_SMOKE_TEST_CONNECT=true
